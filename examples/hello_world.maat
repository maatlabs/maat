// Minimal program demonstrating let bindings, string literals, and print.

let greeting = "Hello, Maat!";
println!("{greeting}");

let language = "Maat";
let version = "0.12.2";
println!("Welcome to {language} v{version}");

// Numeric bindings and basic expressions
let answer = 42;
println!("{answer}");

// Boolean literals
let is_zk = true;
println!("{is_zk}");
