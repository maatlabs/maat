// Integration of all features: generics, structs, enums, traits, closures, stdlib,
// ranges, Sets, Result handling, recursion, and complex match patterns.

use std::math::gcd;
use std::collections::new_set;
use std::collections::set_insert;
use std::collections::set_contains;
use std::collections::set_len;
use std::collections::set_to_array;

// Graph node with adjacency list representation
struct Graph {
    size: i64,
    edges: [[i64]],
}

// Build an adjacency list from a list of (from, to) edge pairs
fn build_graph(size: i64, edge_pairs: [[i64]]) -> Graph {
    fn init_adj(n: i64, acc: [[i64]]) -> [[i64]] {
        if (n == 0) {
            acc
        } else {
            init_adj(n - 1, acc.push([]))
        }
    }

    let mut adj = init_adj(size, []);

    for pair in edge_pairs {
        let from = pair[0];
        let to = pair[1];
        let mut new_adj = [];
        for i in 0..size {
            if (i == from) {
                new_adj = new_adj.push(adj[i].push(to));
            } else if (i == to) {
                new_adj = new_adj.push(adj[i].push(from));
            } else {
                new_adj = new_adj.push(adj[i]);
            }
        }
        adj = new_adj;
    }

    Graph { size: size, edges: adj }
}

// Depth-first search: returns visited set and traversal order
struct DfsResult {
    visited: Set,
    order: [i64],
}

fn dfs(graph: Graph, start: i64) -> DfsResult {
    fn go(graph: Graph, node: i64, visited: Set, order: [i64]) -> DfsResult {
        if (visited.contains(node)) {
            DfsResult { visited: visited, order: order }
        } else {
            let new_visited = visited.insert(node);
            let new_order = order.push(node);
            let neighbors = graph.edges[node];

            fn visit_neighbors(
                graph: Graph,
                neighbors: [i64],
                idx: i64,
                state: DfsResult,
            ) -> DfsResult {
                if (idx as usize >= neighbors.len()) {
                    state
                } else {
                    let neighbor = neighbors[idx];
                    let next = go(graph, neighbor, state.visited, state.order);
                    visit_neighbors(graph, neighbors, idx + 1, next)
                }
            }

            visit_neighbors(
                graph,
                neighbors,
                0,
                DfsResult { visited: new_visited, order: new_order },
            )
        }
    }
    go(graph, start, Set::new(), [])
}

// Build a small graph:
//   0 -- 1 -- 3
//   |    |
//   2 -- 4 -- 5
let edges = [[0, 1], [0, 2], [1, 3], [1, 4], [2, 4], [4, 5]];
let graph = build_graph(6, edges);

let result = dfs(graph, 0);
print(result.order);
print(result.visited.len());

// Verify all nodes were visited
let mut all_visited = true;
for i in 0..6 {
    if (!result.visited.contains(i)) {
        all_visited = false;
    }
}
print(all_visited);

// Mathematical computations using stdlib
// Compute Euler's totient function: count integers 1..n coprime to n
fn euler_totient(n: i64) -> i64 {
    let mut count: i64 = 0;
    for i in 1..n {
        if (gcd(i, n) == 1) {
            count += 1;
        }
    }
    count
}

print(euler_totient(12));
print(euler_totient(30));

// Result-based safe operations pipeline
fn safe_div(a: i64, b: i64) -> Result<i64, str> {
    if (b == 0) {
        Result::Err("division by zero")
    } else {
        Result::Ok(a / b)
    }
}

fn chain_ops(values: [i64]) -> Result<i64, str> {
    if (values.len() < 2usize) {
        return Result::Err("need at least 2 values");
    }
    let mut acc = values[0];
    let mut i: i64 = 1;
    while (i as usize < values.len()) {
        match safe_div(acc, values[i]) {
            Ok(v) => { acc = v + values[i]; },
            Err(e) => { return Result::Err(e); },
        }
        i += 1;
    }
    Result::Ok(acc)
}

print(match chain_ops([100, 5, 3, 2]) { Ok(v) => v, Err(e) => -1 });
print(match chain_ops([100, 0, 3]) { Ok(v) => v, Err(e) => -1 });

// Enum-based expression evaluator (mini calculator)
enum CalcExpr {
    Num(i64),
    Add(i64, i64),
    Mul(i64, i64),
    Neg(i64),
}

fn eval_calc(expr: CalcExpr) -> i64 {
    match expr {
        Num(n) => n,
        Add(a, b) => a + b,
        Mul(a, b) => a * b,
        Neg(n) => -n,
    }
}

print(eval_calc(CalcExpr::Num(42)));
print(eval_calc(CalcExpr::Add(10, 20)));
print(eval_calc(CalcExpr::Mul(6, 7)));
print(eval_calc(CalcExpr::Neg(99)));

// Closure-based accumulator with Set tracking
let process_batch = fn(data: [i64]) {
    let mut seen = Set::new();
    let mut unique_sum: i64 = 0;
    let mut duplicates: i64 = 0;
    for item in data {
        if (seen.contains(item)) {
            duplicates += 1;
        } else {
            seen = seen.insert(item);
            unique_sum += item;
        }
    }
    [unique_sum, duplicates, seen.len() as i64]
};

let batch = [5, 3, 8, 3, 1, 5, 9, 1, 8, 7];
let stats = process_batch(batch);
print(stats);

// Nested struct with complex match
struct Pair {
    left: Option<i64>,
    right: Option<i64>,
}

fn combine_pair(p: Pair) -> i64 {
    let l = match p.left { Some(v) => v, None => 0 };
    let r = match p.right { Some(v) => v, None => 0 };
    l + r
}

print(combine_pair(Pair {
    left: Option::Some(10),
    right: Option::Some(20),
}));
print(combine_pair(Pair {
    left: Option::Some(10),
    right: Option::None,
}));
print(combine_pair(Pair {
    left: Option::None,
    right: Option::None,
}));

// Deep recursion: compute Collatz sequence length
fn collatz_length(n: i64) -> i64 {
    fn go(n: i64, steps: i64) -> i64 {
        if (n == 1) {
            steps
        } else if (n % 2 == 0) {
            go(n / 2, steps + 1)
        } else {
            go(3 * n + 1, steps + 1)
        }
    }
    go(n, 0)
}

print(collatz_length(27));
print(collatz_length(1));
print(collatz_length(1000));

// Final: compute sum of collatz lengths for 1..=20 using range + accumulator
let mut total_steps: i64 = 0;
for n in 1..=20 {
    total_steps += collatz_length(n);
}
print(total_steps);
